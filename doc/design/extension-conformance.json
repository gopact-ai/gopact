  "readme_template_path": "doc/design/extension-repository-template.md",
  "scaffold": {
    "repository_owner": "gopact-ai",
    "module_path_prefix": "github.com/gopact-ai/",
    "ci_workflow_template_path": "doc/design/extension-ci-workflow.yml",
    "conformance_template_path": "doc/design/extension-conformance-template.md",
    "required_files": [
      "go.mod",
      "README.md",
      "CONFORMANCE.md",
      "examples/minimal_test.go",
      ".github/workflows/ci.yml"
    ],
    "checklist": [
      "host-owned config",
      "offline conformance",
      "extension scaffold conformance",
      "integration build tags",
      "no production adapter in core repo"
    ]
  },
  "required_ci_commands": [
    "git diff --check",
    "go mod tidy && git diff --exit-code",
    "go test -count=1 ./...",
    "go vet ./..."
  ],
