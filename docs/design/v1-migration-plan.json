        "external_repository_readiness"
      ],
      "source_manifests": [
        "docs/design/external-repositories.json",
        "docs/design/extension-scaffold-spec.json",
        "docs/design/extension-conformance.json"
      ],
      "required_status": "passed",
      "blocking_status": "failed",
      "blocker_summary": "Every external gopact-ai adapter/plugin/template repository must exist, match expected visibility, expose CI, provide GOPACT_GITHUB_TOKEN while the core SDK is private, and have latest CI passing before v1 release."
    },
    {
      "id": "extension-conformance",
      "evidence_types": [
        "command",
        "file_snapshot"
      ],
      "source_manifests": [
        "docs/design/extension-conformance.json",
        "docs/design/extension-conformance-template.md",
        "docs/design/extension-scaffold-spec.json"
      ],
      "required_status": "passed",
      "blocking_status": "failed",
      "blocker_summary": "Every extension target referenced by the v1 migration plan must keep its scaffold, required conformance suites, examples, and generated repository contract passing before v1 release."
    },
    {
      "id": "public-api-examples",
      "evidence_types": [
        "command",
        "file_snapshot"
      ],
      "source_manifests": [
        "docs/design/public-api-boundary.json",
        "docs/design/public-api-examples.json"
      ],
      "required_status": "passed",
      "blocking_status": "failed",
      "blocker_summary": "Every stable or transitional root public API required for v1 must be covered by public-api-boundary.json and executable public API examples before v1 release."
    },
    {
      "id": "public-api-boundary",
      "evidence_types": [
        "file_snapshot"
      ],
      "source_manifests": [
        "docs/design/public-api-boundary.json",
        "docs/design/deprecation-policy.md",
        "docs/design/api-ergonomics.md"
      ],
      "required_status": "passed",
      "blocking_status": "failed",
      "blocker_summary": "Every root exported API that remains visible at v1 must be categorized, assigned a stability state, and covered by deprecation policy before v1 release."
    },
    {
      "id": "migration-guide",
      "evidence_types": [
        "file_snapshot"
      ],
      "source_manifests": [
        "docs/design/migration-guide.md",
        "docs/design/deprecation-policy.md",
        "docs/design/versioning-policy.md"
      ],
      "required_status": "passed",
      "blocking_status": "failed",
      "blocker_summary": "The v1 migration guide, deprecation policy, and versioning policy must describe every public API transition or repository migration that remains visible to SDK users before v1 release."
    }
  ],
