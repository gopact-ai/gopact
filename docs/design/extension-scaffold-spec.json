{
  "version": 1,
  "source_manifests": [
    "docs/design/external-repositories.json",
    "docs/design/extension-conformance.json",
    "docs/design/extension-repository-template.md",
    "docs/design/extension-conformance-template.md",
    "docs/design/extension-ci-workflow.yml"
  ],
  "file_templates": [
    {
      "path": "go.mod",
      "content_rules": [
        "module line must equal the repository module_path",
        "go version must match extension-conformance sdk_compatibility.go_versions",
        "require github.com/gopact-ai/gopact with an explicit version or local replace only during development",
        "do not load SDK-owned configuration files"
      ]
    },
    {
      "path": "README.md",
      "template_path": "docs/design/extension-repository-template.md",
      "content_rules": [
        "fill compatibility from extension-conformance.json",
        "document host-owned config",
        "show one minimal constructor-based example"
      ]
    },
    {
      "path": "CONFORMANCE.md",
      "template_path": "docs/design/extension-conformance-template.md",
      "content_rules": [
        "list every target in the repository",
        "list every required suite for each target",
        "document offline default tests and optional integration build tags",
        "record known gopacttest helper references when the scaffold catalog maps a suite to one"
      ]
    },
    {
      "path": "examples/minimal_test.go",
      "content_rules": [
        "compile without live external services",
        "exercise host-injected clients, stores, policies, or transports",
        "call gopacttest.RequireExtensionScaffoldConformance for repository layout",
        "machine-check known gopacttest helper references recorded in CONFORMANCE.md"
      ]
    },
    {
      "path": ".github/workflows/ci.yml",
      "template_path": "docs/design/extension-ci-workflow.yml",
      "content_rules": [
        "run git diff --check",
        "run go test -count=1 ./...",
        "run go vet ./..."
      ]
    }
  ],
  "repositories": [
    {
      "name": "gopact-adapters-model",
      "module_path": "github.com/gopact-ai/gopact-adapters-model",
      "targets": [
        {
          "name": "gopact-adapters-model-openaicompatible",
          "package_path": "openaicompatible",
          "minimal_example_path": "examples/minimal_test.go"
        }
      ]
    },
    {
      "name": "gopact-adapters-checkpoint",
      "module_path": "github.com/gopact-ai/gopact-adapters-checkpoint",
      "targets": [
        {
          "name": "gopact-adapters-checkpoint-gcs",
          "package_path": "gcsstore",
          "minimal_example_path": "examples/minimal_test.go"
        },
        {
          "name": "gopact-adapters-checkpoint-oss",
          "package_path": "ossstore",
          "minimal_example_path": "examples/minimal_test.go"
        },
        {
          "name": "gopact-adapters-checkpoint-r2",
