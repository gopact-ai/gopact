{
  "version": 1,
  "lifecycle": "migration-history",
  "superseded_by": "docs/design/ecosystem-topology.json",
  "organization": "gopact-ai",
  "default_visibility": "private",
  "module_path_prefix": "github.com/gopact-ai/",
  "bootstrap_sequence": [
    "create-private-repos",
    "copy-scaffold-files",
    "wire-conformance-suites",
    "enable-private-ci",
    "publish-compatibility-matrix"
  ],
  "repositories": [
    {
      "name": "gopact-adapters-model",
      "route": "adapter-repo",
      "visibility": "private",
      "module_path": "github.com/gopact-ai/gopact-adapters-model",
      "scaffold_status": "ready-to-create",
      "host_owned_config": true,
      "extension_targets": [
        "gopact-adapters-model-openaicompatible"
      ],
      "required_files": [
        "go.mod",
        "README.md",
        "CONFORMANCE.md",
        "examples/minimal_test.go",
        ".github/workflows/ci.yml"
      ],
      "required_ci_commands": [
        "git diff --check",
        "go mod tidy && git diff --exit-code",
        "go test -count=1 ./...",
        "go vet ./..."
      ]
    },
    {
